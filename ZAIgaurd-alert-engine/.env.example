# =====================================================================
# ZaiGuard Alert Engine — Environment Configuration Template (.env.example)
# =====================================================================
# Copy this file to .env and adjust values for your local environment:
#    cp .env.example .env
# =====================================================================

# Application Environment
APP_ENV=development
LOG_LEVEL=DEBUG

# PostgreSQL / TimescaleDB Settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=zaiguard
POSTGRES_PASSWORD=zaiguard_dev
POSTGRES_DB=zaiguard

# Redis Deduplication & Cache Store
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_DISMISSED=dismissed_alerts
QDRANT_COLLECTION_CONFIRMED=confirmed_alerts

# Sentence Transformer Embedding Model
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=./.model_cache

# Config Layer Cache TTL
CONFIG_CACHE_TTL_SECONDS=60
